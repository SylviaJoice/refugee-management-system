<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <%- include('../partials/header') %>
    <div class="app-body">
      <%- include('../partials/sidebar') %>
      <main class="content p-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <h1>Refugee Details</h1>
          <a href="/refugees" class="btn btn-outline-secondary">Back</a>
        </div>
        <%- include('../partials/messages') %>
        <div class="row gy-4">
          <div class="col-md-6">
            <div class="card shadow-sm p-4">
              <h4>Personal Information</h4>
              <p><strong>Name:</strong> <%= refugee.full_name %></p>
              <p><strong>Gender:</strong> <%= refugee.gender %></p>
              <p><strong>Age:</strong> <%= refugee.age %></p>
              <p><strong>Nationality:</strong> <%= refugee.nationality %></p>
              <p><strong>Phone:</strong> <%= refugee.phone_number %></p>
              <p><strong>Status:</strong> <%= refugee.refugee_status %></p>
              <p><strong>Shelter:</strong> <%= refugee.shelter_name || 'No shelter assigned' %></p>
            </div>
          </div>
          <div class="col-md-6">
            <div class="card shadow-sm p-4">
              <h4>Family Members</h4>
              <% if (family.length) { %>
                <ul class="list-group">
                  <% family.forEach((member) => { %>
                    <li class="list-group-item">
                      <strong><%= member.member_name %></strong> - <%= member.relationship %> (<%= member.age %>, <%= member.gender %>)
                    </li>
                  <% }); %>
                </ul>
              <% } else { %>
                <p>No family members added yet.</p>
              <% } %>
            </div>
          </div>
        </div>
      </main>
    </div>
    <%- include('../partials/footer') %>
  </body>
</html>
