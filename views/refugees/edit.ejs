<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <%- include('../partials/header') %>
    <div class="app-body">
      <%- include('../partials/sidebar') %>
      <main class="content p-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <h1>Edit Refugee</h1>
          <a href="/refugees" class="btn btn-outline-secondary">Back</a>
        </div>
        <%- include('../partials/messages') %>
        <div class="card shadow-sm p-4">
          <form action="/refugees/edit/<%= refugee.refugee_id %>" method="post" novalidate>
            <div class="row g-3">
              <div class="col-md-6">
                <label class="form-label">Full Name</label>
                <input type="text" name="full_name" class="form-control" value="<%= refugee.full_name %>" required />
              </div>
              <div class="col-md-3">
                <label class="form-label">Gender</label>
                <select name="gender" class="form-select" required>
                  <option value="">Select gender</option>
                  <option <%= refugee.gender === 'Male' ? 'selected' : '' %>>Male</option>
                  <option <%= refugee.gender === 'Female' ? 'selected' : '' %>>Female</option>
                  <option <%= refugee.gender === 'Other' ? 'selected' : '' %>>Other</option>
                </select>
              </div>
              <div class="col-md-3">
                <label class="form-label">Age</label>
                <input type="number" name="age" class="form-control" min="0" value="<%= refugee.age %>" required />
              </div>
              <div class="col-md-6">
                <label class="form-label">Nationality</label>
                <input type="text" name="nationality" class="form-control" value="<%= refugee.nationality %>" required />
              </div>
              <div class="col-md-6">
                <label class="form-label">Phone Number</label>
                <input type="text" name="phone_number" class="form-control" value="<%= refugee.phone_number %>" required />
              </div>
              <div class="col-md-6">
                <label class="form-label">Refugee Status</label>
                <select name="refugee_status" class="form-select" required>
                  <option value="">Select status</option>
                  <option value="Pending" <%= refugee.refugee_status === 'Pending' ? 'selected' : '' %>>Pending</option>
                  <option value="Approved" <%= refugee.refugee_status === 'Approved' ? 'selected' : '' %>>Approved</option>
                </select>
              </div>
              <div class="col-md-6">
                <label class="form-label">Shelter</label>
                <select name="shelter_id" class="form-select">
                  <option value="">Unassigned</option>
                  <% shelters.forEach((shelter) => { %>
                    <option value="<%= shelter.shelter_id %>" <%= refugee.shelter_id === shelter.shelter_id ? 'selected' : '' %>><%= shelter.shelter_name %> - <%= shelter.location %></option>
                  <% }); %>
                </select>
              </div>
              <div class="col-12 text-end">
                <button type="submit" class="btn btn-primary">Save Changes</button>
              </div>
            </div>
          </form>
        </div>
      </main>
    </div>
    <%- include('../partials/footer') %>
  </body>
</html>
