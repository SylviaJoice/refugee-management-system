<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <%- include('../partials/header') %>
    <div class="app-body">
      <%- include('../partials/sidebar') %>
      <main class="content p-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <h1>Complaints</h1>
          <a href="/complaints/add" class="btn btn-primary">Add Complaint</a>
        </div>
        <%- include('../partials/messages') %>
        <div class="table-responsive">
          <table class="table table-hover align-middle">
            <thead class="table-light">
              <tr>
                <th>Refugee</th>
                <th>Title</th>
                <th>Status</th>
                <th>Created At</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% complaints.forEach((complaint) => { %>
                <tr>
                  <td><%= complaint.full_name %></td>
                  <td><%= complaint.complaint_title %></td>
                  <td><%= complaint.complaint_status %></td>
                  <td><%= complaint.created_at.toISOString().slice(0, 10) %></td>
                  <td>
                    <a href="/complaints/edit/<%= complaint.complaint_id %>" class="btn btn-sm btn-secondary">Edit</a>
                    <form action="/complaints/delete/<%= complaint.complaint_id %>" method="post" class="d-inline">
                      <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Delete this complaint?');">Delete</button>
                    </form>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </main>
    </div>
    <%- include('../partials/footer') %>
  </body>
</html>
