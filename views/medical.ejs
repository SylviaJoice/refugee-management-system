<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body class="bg-light">
    <%- include('partials/header') %>

    <div class="container-fluid">
      <div class="row">
        <div class="col-md-2 px-0">
          <%- include('partials/sidebar') %>
        </div>
        <div class="col-md-10 px-4 py-4">
          <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="h3 mb-0 text-dark">
              <i class="fas fa-stethoscope me-2 text-danger"></i>Medical Records Management
            </h1>
            <a href="/medical/add" class="btn btn-danger">
              <i class="fas fa-plus me-2"></i>Add Medical Record
            </a>
          </div>

          <%- include('partials/messages') %>

          <!-- Search and Filter -->
          <div class="card border-0 shadow-sm mb-4">
            <div class="card-body">
              <form class="row g-3" method="get">
                <div class="col-md-8">
                  <label for="search" class="form-label">Search Medical Records</label>
                  <input type="text" name="search" id="search" class="form-control"
                         placeholder="Search by refugee name or condition..." value="<%= search || '' %>">
                </div>
                <div class="col-md-4">
                  <label class="form-label">&nbsp;</label>
                  <div class="d-grid">
                    <button type="submit" class="btn btn-outline-danger">
                      <i class="fas fa-search me-2"></i>Search
                    </button>
                  </div>
                </div>
              </form>
            </div>
          </div>

          <!-- Medical Records Table -->
          <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3">
              <h5 class="mb-0">
                <i class="fas fa-list me-2 text-danger"></i>Medical Records List
                <span class="badge bg-danger ms-2"><%= medicalRecords ? medicalRecords.length : 0 %> Records</span>
              </h5>
            </div>
            <div class="card-body p-0">
              <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                  <thead class="table-light">
                    <tr>
                      <th class="border-0 fw-semibold px-4 py-3">Refugee</th>
                      <th class="border-0 fw-semibold px-4 py-3">Medical Condition</th>
                      <th class="border-0 fw-semibold px-4 py-3">Severity</th>
                      <th class="border-0 fw-semibold px-4 py-3">Treatment</th>
                      <th class="border-0 fw-semibold px-4 py-3">Date Recorded</th>
                      <th class="border-0 fw-semibold px-4 py-3 text-center">Actions</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% if (medicalRecords && medicalRecords.length > 0) { %>
                      <% medicalRecords.forEach((record) => { %>
                        <tr>
                          <td class="px-4 py-3">
                            <div class="d-flex align-items-center">
                              <div class="bg-danger bg-opacity-10 p-2 rounded-circle me-3">
                                <i class="fas fa-user text-danger"></i>
                              </div>
                              <div>
                                <div class="fw-semibold"><%= record.full_name %></div>
                                <small class="text-muted">Refugee ID: <%= record.refugee_id %></small>
                              </div>
                            </div>
                          </td>
                          <td class="px-4 py-3">
                            <div>
                              <div class="fw-semibold"><%= record.medical_condition %></div>
                              <% if (record.description) { %>
                                <small class="text-muted"><%= record.description %></small>
                              <% } %>
                            </div>
                          </td>
                          <td class="px-4 py-3">
                            <span class="badge bg-<%= record.severity === 'Critical' ? 'danger' : record.severity === 'High' ? 'warning' : record.severity === 'Medium' ? 'info' : 'success' %>">
                              <%= record.severity %>
                            </span>
                          </td>
                          <td class="px-4 py-3">
                            <% if (record.treatment) { %>
                              <span class="fw-semibold"><%= record.treatment %></span>
                            <% } else { %>
                              <span class="text-muted">No treatment specified</span>
                            <% } %>
                          </td>
                          <td class="px-4 py-3">
                            <i class="fas fa-calendar text-muted me-2"></i>
                            <%= new Date(record.date_recorded).toLocaleDateString() %>
                          </td>
                          <td class="px-4 py-3 text-center">
                            <div class="btn-group" role="group">
                              <a href="/medical/edit/<%= record.medical_id %>"
                                 class="btn btn-sm btn-outline-primary" title="Edit">
                                <i class="fas fa-edit"></i>
                              </a>
                              <button type="button" class="btn btn-sm btn-outline-danger"
                                      onclick="confirmDelete(<%= record.medical_id %>, '<%= record.medical_condition %> for <%= record.full_name %>')"
                                      title="Delete">
                                <i class="fas fa-trash"></i>
                              </button>
                            </div>
                          </td>
                        </tr>
                      <% }); %>
                    <% } else { %>
                      <tr>
                        <td colspan="6" class="text-center py-5">
                          <div class="text-muted">
                            <i class="fas fa-stethoscope fa-3x mb-3"></i>
                            <p class="mb-0">No medical records found.</p>
                            <a href="/medical/add" class="btn btn-danger btn-sm mt-2">
                              <i class="fas fa-plus me-1"></i>Add First Medical Record
                            </a>
                          </div>
                        </td>
                      </tr>
                    <% } %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>

          <!-- Pagination -->
          <% if (medicalRecords && medicalRecords.length > 0) { %>
            <nav aria-label="Medical records pagination" class="mt-4">
              <ul class="pagination justify-content-center">
                <li class="page-item <%= currentPage <= 1 ? 'disabled' : '' %>">
                  <a class="page-link" href="?page=<%= currentPage - 1 %><%= search ? '&search=' + search : '' %>">
                    <i class="fas fa-chevron-left"></i> Previous
                  </a>
                </li>
                <% for (let i = Math.max(1, currentPage - 2); i <= Math.min(totalPages, currentPage + 2); i++) { %>
                  <li class="page-item <%= i === currentPage ? 'active' : '' %>">
                    <a class="page-link" href="?page=<%= i %><%= search ? '&search=' + search : '' %>"><%= i %></a>
                  </li>
                <% } %>
                <li class="page-item <%= currentPage >= totalPages ? 'disabled' : '' %>">
                  <a class="page-link" href="?page=<%= currentPage + 1 %><%= search ? '&search=' + search : '' %>">
                    Next <i class="fas fa-chevron-right"></i>
                  </a>
                </li>
              </ul>
            </nav>
          <% } %>
        </div>
      </div>
    </div>

    <%- include('partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
      function confirmDelete(id, description) {
        if (confirm(`Are you sure you want to delete this medical record: "${description}"? This action cannot be undone.`)) {
          const form = document.createElement('form');
          form.method = 'POST';
          form.action = `/medical/delete/${id}`;
          document.body.appendChild(form);
          form.submit();
        }
      }
    </script>
  </body>
</html>