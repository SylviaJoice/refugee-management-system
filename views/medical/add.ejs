<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <%- include('../partials/header') %>
    <div class="app-body">
      <%- include('../partials/sidebar') %>
      <main class="content p-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <h1>Add Medical Record</h1>
          <a href="/medical" class="btn btn-outline-secondary">Back</a>
        </div>
        <%- include('../partials/messages') %>
        <div class="card shadow-sm p-4">
          <form action="/medical/add" method="post" novalidate>
            <div class="row g-3">
              <div class="col-md-6">
                <label class="form-label">Refugee</label>
                <select name="refugee_id" class="form-select" required>
                  <option value="">Select refugee</option>
                  <% refugees.forEach((refugee) => { %>
                    <option value="<%= refugee.refugee_id %>"><%= refugee.full_name %></option>
                  <% }); %>
                </select>
              </div>
              <div class="col-md-6">
                <label class="form-label">Illness</label>
                <input type="text" name="illness" class="form-control" required />
              </div>
              <div class="col-md-6">
                <label class="form-label">Treatment</label>
                <input type="text" name="treatment" class="form-control" required />
              </div>
              <div class="col-md-6">
                <label class="form-label">Doctor Name</label>
                <input type="text" name="doctor_name" class="form-control" required />
              </div>
              <div class="col-md-6">
                <label class="form-label">Visit Date</label>
                <input type="date" name="visit_date" class="form-control" required />
              </div>
              <div class="col-12 text-end">
                <button type="submit" class="btn btn-primary">Save Medical Record</button>
              </div>
            </div>
          </form>
        </div>
      </main>
    </div>
    <%- include('../partials/footer') %>
  </body>
</html>
