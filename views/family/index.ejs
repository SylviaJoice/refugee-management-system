<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <%- include('../partials/header') %>
    <div class="app-body">
      <%- include('../partials/sidebar') %>
      <main class="content p-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <h1>Family Members</h1>
          <a href="/family/add" class="btn btn-primary">Add Family Member</a>
        </div>
        <%- include('../partials/messages') %>
        <div class="table-responsive">
          <table class="table table-hover align-middle">
            <thead class="table-light">
              <tr>
                <th>Family Member</th>
                <th>Relationship</th>
                <th>Age</th>
                <th>Gender</th>
                <th>Refugee</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% familyMembers.forEach((member) => { %>
                <tr>
                  <td><%= member.member_name %></td>
                  <td><%= member.relationship %></td>
                  <td><%= member.age %></td>
                  <td><%= member.gender %></td>
                  <td><%= member.full_name %></td>
                  <td>
                    <a href="/family/edit/<%= member.member_id %>" class="btn btn-sm btn-secondary">Edit</a>
                    <form action="/family/delete/<%= member.member_id %>" method="post" class="d-inline">
                      <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Delete this family member?');">Delete</button>
                    </form>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </main>
    </div>
    <%- include('../partials/footer') %>
  </body>
</html>
