<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <%- include('../partials/header') %>
    <div class="app-body">
      <%- include('../partials/sidebar') %>
      <main class="content p-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <h1>Edit Family Member</h1>
          <a href="/family" class="btn btn-outline-secondary">Back</a>
        </div>
        <%- include('../partials/messages') %>
        <div class="card shadow-sm p-4">
          <form action="/family/edit/<%= member.member_id %>" method="post" novalidate>
            <div class="row g-3">
              <div class="col-md-6">
                <label class="form-label">Refugee</label>
                <select name="refugee_id" class="form-select" required>
                  <% refugees.forEach((refugee) => { %>
                    <option value="<%= refugee.refugee_id %>" <%= refugee.refugee_id === member.refugee_id ? 'selected' : '' %>><%= refugee.full_name %></option>
                  <% }); %>
                </select>
              </div>
              <div class="col-md-6">
                <label class="form-label">Member Name</label>
                <input type="text" name="member_name" class="form-control" value="<%= member.member_name %>" required />
              </div>
              <div class="col-md-4">
                <label class="form-label">Relationship</label>
                <input type="text" name="relationship" class="form-control" value="<%= member.relationship %>" required />
              </div>
              <div class="col-md-4">
                <label class="form-label">Age</label>
                <input type="number" name="age" class="form-control" min="0" value="<%= member.age %>" required />
              </div>
              <div class="col-md-4">
                <label class="form-label">Gender</label>
                <select name="gender" class="form-select" required>
                  <option value="">Select gender</option>
                  <option <%= member.gender === 'Male' ? 'selected' : '' %>>Male</option>
                  <option <%= member.gender === 'Female' ? 'selected' : '' %>>Female</option>
                  <option <%= member.gender === 'Other' ? 'selected' : '' %>>Other</option>
                </select>
              </div>
              <div class="col-12 text-end">
                <button type="submit" class="btn btn-primary">Save Changes</button>
              </div>
            </div>
          </form>
        </div>
      </main>
    </div>
    <%- include('../partials/footer') %>
  </body>
</html>
