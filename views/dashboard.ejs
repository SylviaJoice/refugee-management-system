<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body class="bg-light">
    <%- include('partials/header') %>

    <div class="container-fluid">
      <div class="row">
        <div class="col-md-2 px-0">
          <%- include('partials/sidebar') %>
        </div>
        <div class="col-md-10 px-4 py-4">
          <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="h3 mb-0 text-dark">
              <i class="fas fa-tachometer-alt me-2 text-primary"></i>Dashboard
            </h1>
            <div class="text-muted">
              Welcome back, <%= user ? user.username : 'Admin' %>
            </div>
          </div>

          <%- include('partials/messages') %>

          <!-- Statistics Cards -->
          <div class="row g-4 mb-4">
            <div class="col-xl-3 col-md-6">
              <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                  <div class="d-flex align-items-center justify-content-center mb-3">
                    <div class="bg-primary bg-opacity-10 p-3 rounded-circle">
                      <i class="fas fa-users fa-2x text-primary"></i>
                    </div>
                  </div>
                  <h5 class="card-title text-muted mb-2">Total Refugees</h5>
                  <h2 class="text-primary mb-0"><%= totalRefugees || 0 %></h2>
                </div>
              </div>
            </div>
            <div class="col-xl-3 col-md-6">
              <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                  <div class="d-flex align-items-center justify-content-center mb-3">
                    <div class="bg-success bg-opacity-10 p-3 rounded-circle">
                      <i class="fas fa-building fa-2x text-success"></i>
                    </div>
                  </div>
                  <h5 class="card-title text-muted mb-2">Total Shelters</h5>
                  <h2 class="text-success mb-0"><%= totalShelters || 0 %></h2>
                </div>
              </div>
            </div>
            <div class="col-xl-3 col-md-6">
              <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                  <div class="d-flex align-items-center justify-content-center mb-3">
                    <div class="bg-warning bg-opacity-10 p-3 rounded-circle">
                      <i class="fas fa-exclamation-triangle fa-2x text-warning"></i>
                    </div>
                  </div>
                  <h5 class="card-title text-muted mb-2">Total Complaints</h5>
                  <h2 class="text-warning mb-0"><%= totalComplaints || 0 %></h2>
                </div>
              </div>
            </div>
            <div class="col-xl-3 col-md-6">
              <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                  <div class="d-flex align-items-center justify-content-center mb-3">
                    <div class="bg-info bg-opacity-10 p-3 rounded-circle">
                      <i class="fas fa-hand-holding-heart fa-2x text-info"></i>
                    </div>
                  </div>
                  <h5 class="card-title text-muted mb-2">Total Aid Records</h5>
                  <h2 class="text-info mb-0"><%= totalAidRecords || 0 %></h2>
                </div>
              </div>
            </div>
          </div>

          <!-- Additional Stats Row -->
          <div class="row g-4 mb-4">
            <div class="col-xl-3 col-md-6">
              <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                  <div class="d-flex align-items-center justify-content-center mb-3">
                    <div class="bg-danger bg-opacity-10 p-3 rounded-circle">
                      <i class="fas fa-stethoscope fa-2x text-danger"></i>
                    </div>
                  </div>
                  <h5 class="card-title text-muted mb-2">Medical Records</h5>
                  <h2 class="text-danger mb-0"><%= totalMedicalRecords || 0 %></h2>
                </div>
              </div>
            </div>
            <div class="col-xl-3 col-md-6">
              <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                  <div class="d-flex align-items-center justify-content-center mb-3">
                    <div class="bg-secondary bg-opacity-10 p-3 rounded-circle">
                      <i class="fas fa-user-friends fa-2x text-secondary"></i>
                    </div>
                  </div>
                  <h5 class="card-title text-muted mb-2">Family Members</h5>
                  <h2 class="text-secondary mb-0"><%= totalFamilyMembers || 0 %></h2>
                </div>
              </div>
            </div>
          </div>

          <!-- Quick Actions -->
          <div class="card border-0 shadow-sm">
            <div class="card-header bg-white">
              <h5 class="mb-0">
                <i class="fas fa-bolt me-2 text-warning"></i>Quick Actions
              </h5>
            </div>
            <div class="card-body">
              <div class="row g-3">
                <div class="col-md-3">
                  <a href="/refugees/add" class="btn btn-primary w-100">
                    <i class="fas fa-plus me-2"></i>Add Refugee
                  </a>
                </div>
                <div class="col-md-3">
                  <a href="/shelters/add" class="btn btn-success w-100">
                    <i class="fas fa-plus me-2"></i>Add Shelter
                  </a>
                </div>
                <div class="col-md-3">
                  <a href="/aid/add" class="btn btn-info w-100">
                    <i class="fas fa-plus me-2"></i>Add Aid Record
                  </a>
                </div>
                <div class="col-md-3">
                  <a href="/complaints/add" class="btn btn-warning w-100">
                    <i class="fas fa-plus me-2"></i>Add Complaint
                  </a>
                </div>
              </div>
            </div>
          </div>

          <!-- Refugees Table Section -->
          <div class="card border-0 shadow-sm mt-4">
            <div class="card-header bg-white d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3">
              <div>
                <h5 class="mb-1">Refugees Overview</h5>
                <p class="text-muted mb-0">Search, add, update or remove refugee records from the dashboard.</p>
              </div>
              <div class="d-flex flex-wrap gap-2">
                <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#refugeeModal" onclick="openAddModal()">
                  <i class="fas fa-plus me-1"></i> Add Refugee
                </button>
                <button type="button" class="btn btn-success" onclick="openUpdateModal()">
                  <i class="fas fa-edit me-1"></i> Update Refugee
                </button>
                <button type="button" class="btn btn-danger" onclick="confirmDeleteSelected()">
                  <i class="fas fa-trash me-1"></i> Delete Refugee
                </button>
              </div>
            </div>
            <div class="card-body">
              <form class="row gy-3 gx-3 align-items-end mb-4" method="get">
                <div class="col-md-8">
                  <label for="searchQuery" class="form-label mb-1">Filter by ID or Name</label>
                  <input type="text" id="searchQuery" name="search" class="form-control" placeholder="Search refugees by ID or name" value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>">
                </div>
                <div class="col-md-4">
                  <button type="submit" class="btn btn-outline-primary w-100">
                    <i class="fas fa-search me-2"></i>Search
                  </button>
                </div>
              </form>

              <% const refugeeList = typeof refugees !== 'undefined' ? refugees : [{
                    refugee_id: 'R001',
                    full_name: 'Amina Yusuf',
                    age: 29,
                    gender: 'Female',
                    shelter_name: 'Hope Shelter'
                  },
                  {
                    refugee_id: 'R002',
                    full_name: 'Karim Hassan',
                    age: 35,
                    gender: 'Male',
                    shelter_name: 'Unity House'
                  }]; %>

              <div class="table-responsive">
                <table class="table table-striped table-bordered align-middle mb-0">
                  <thead class="table-light">
                    <tr>
                      <th scope="col">Select</th>
                      <th scope="col">ID</th>
                      <th scope="col">Name</th>
                      <th scope="col">Age</th>
                      <th scope="col">Gender</th>
                      <th scope="col">Shelter</th>
                      <th scope="col" class="text-center">Actions</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% refugeeList.forEach((refugee) => { %>
                      <tr>
                        <td>
                          <input type="radio" name="selectedRefugee" value="<%= refugee.refugee_id %>" data-name="<%= refugee.full_name %>" data-age="<%= refugee.age %>" data-gender="<%= refugee.gender %>" data-shelter="<%= refugee.shelter_name %>">
                        </td>
                        <td><%= refugee.refugee_id %></td>
                        <td><%= refugee.full_name %></td>
                        <td><%= refugee.age %></td>
                        <td><%= refugee.gender %></td>
                        <td><%= refugee.shelter_name %></td>
                        <td class="text-center">
                          <button type="button" class="btn btn-sm btn-success me-1" onclick="populateUpdateModal(this)">
                            <i class="fas fa-edit"></i>
                          </button>
                          <button type="button" class="btn btn-sm btn-danger" onclick="confirmRowDelete('<%= refugee.refugee_id %>','<%= refugee.full_name %>')">
                            <i class="fas fa-trash"></i>
                          </button>
                        </td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>

          <!-- Refugee Add/Update Modal -->
          <div class="modal fade" id="refugeeModal" tabindex="-1" aria-labelledby="refugeeModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-lg modal-dialog-centered">
              <div class="modal-content">
                <div class="modal-header">
                  <h5 class="modal-title" id="refugeeModalLabel">Add Refugee</h5>
                  <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form id="refugeeForm">
                  <div class="modal-body">
                    <div class="row g-3">
                      <div class="col-md-6">
                        <label for="refugeeId" class="form-label">Refugee ID</label>
                        <input type="text" id="refugeeId" name="refugee_id" class="form-control" placeholder="R001">
                      </div>
                      <div class="col-md-6">
                        <label for="refugeeName" class="form-label">Full Name</label>
                        <input type="text" id="refugeeName" name="full_name" class="form-control" placeholder="Amina Yusuf">
                      </div>
                      <div class="col-md-4">
                        <label for="refugeeAge" class="form-label">Age</label>
                        <input type="number" id="refugeeAge" name="age" class="form-control" min="0" placeholder="29">
                      </div>
                      <div class="col-md-4">
                        <label for="refugeeGender" class="form-label">Gender</label>
                        <select id="refugeeGender" name="gender" class="form-select">
                          <option value="">Select gender</option>
                          <option value="Female">Female</option>
                          <option value="Male">Male</option>
                          <option value="Other">Other</option>
                        </select>
                      </div>
                      <div class="col-md-4">
                        <label for="refugeeShelter" class="form-label">Shelter</label>
                        <input type="text" id="refugeeShelter" name="shelter_name" class="form-control" placeholder="Hope Shelter">
                      </div>
                    </div>
                  </div>
                  <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Submit</button>
                  </div>
                </form>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <%- include('partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
      const refugeeModal = new bootstrap.Modal(document.getElementById('refugeeModal'));

      function openAddModal() {
        document.getElementById('refugeeModalLabel').textContent = 'Add Refugee';
        document.getElementById('refugeeForm').reset();
      }

      function openUpdateModal() {
        const selected = document.querySelector('input[name="selectedRefugee"]:checked');
        if (!selected) {
          alert('Please select a refugee row to update.');
          return;
        }

        const form = document.getElementById('refugeeForm');
        document.getElementById('refugeeModalLabel').textContent = 'Update Refugee';
        form.refugee_id.value = selected.value;
        form.full_name.value = selected.dataset.name;
        form.age.value = selected.dataset.age;
        form.gender.value = selected.dataset.gender;
        form.shelter_name.value = selected.dataset.shelter;
        refugeeModal.show();
      }

      function populateUpdateModal(button) {
        const row = button.closest('tr');
        const radio = row.querySelector('input[name="selectedRefugee"]');
        radio.checked = true;
        openUpdateModal();
      }

      function confirmDeleteSelected() {
        const selected = document.querySelector('input[name="selectedRefugee"]:checked');
        if (!selected) {
          alert('Please select a refugee row to delete.');
          return;
        }
        confirmRowDelete(selected.value, selected.dataset.name);
      }

      function confirmRowDelete(id, name) {
        if (confirm(`Delete refugee ${name} (${id})? This action cannot be undone.`)) {
          console.log('Delete action for', id);
        }
      }
    </script>
  </body>
</html>