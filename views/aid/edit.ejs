<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <%- include('../partials/header') %>
    <div class="app-body">
      <%- include('../partials/sidebar') %>
      <main class="content p-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <h1>Edit Aid Record</h1>
          <a href="/aid" class="btn btn-outline-secondary">Back</a>
        </div>
        <%- include('../partials/messages') %>
        <div class="card shadow-sm p-4">
          <form action="/aid/edit/<%= record.aid_id %>" method="post" novalidate>
            <div class="row g-3">
              <div class="col-md-6">
                <label class="form-label">Refugee</label>
                <select name="refugee_id" class="form-select" required>
                  <% refugees.forEach((refugee) => { %>
                    <option value="<%= refugee.refugee_id %>" <%= refugee.refugee_id === record.refugee_id ? 'selected' : '' %>><%= refugee.full_name %></option>
                  <% }); %>
                </select>
              </div>
              <div class="col-md-6">
                <label class="form-label">Aid Type</label>
                <input type="text" name="aid_type" class="form-control" value="<%= record.aid_type %>" required />
              </div>
              <div class="col-md-4">
                <label class="form-label">Distribution Date</label>
                <input type="date" name="distribution_date" class="form-control" value="<%= record.distribution_date.toISOString().slice(0, 10) %>" required />
              </div>
              <div class="col-md-4">
                <label class="form-label">Quantity</label>
                <input type="number" name="quantity" class="form-control" min="0" value="<%= record.quantity %>" required />
              </div>
              <div class="col-md-4">
                <label class="form-label">Distributed By</label>
                <input type="text" name="distributed_by" class="form-control" value="<%= record.distributed_by %>" required />
              </div>
              <div class="col-12 text-end">
                <button type="submit" class="btn btn-primary">Save Changes</button>
              </div>
            </div>
          </form>
        </div>
      </main>
    </div>
    <%- include('../partials/footer') %>
  </body>
</html>
