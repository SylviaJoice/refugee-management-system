<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <%- include('../partials/header') %>
    <div class="app-body">
      <%- include('../partials/sidebar') %>
      <main class="content p-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <h1>Aid Distribution</h1>
          <a href="/aid/add" class="btn btn-primary">Add Aid Record</a>
        </div>
        <%- include('../partials/messages') %>
        <div class="table-responsive">
          <table class="table table-hover align-middle">
            <thead class="table-light">
              <tr>
                <th>Refugee</th>
                <th>Aid Type</th>
                <th>Date</th>
                <th>Quantity</th>
                <th>Distributed By</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% records.forEach((record) => { %>
                <tr>
                  <td><%= record.full_name %></td>
                  <td><%= record.aid_type %></td>
                  <td><%= record.distribution_date.toISOString().slice(0, 10) %></td>
                  <td><%= record.quantity %></td>
                  <td><%= record.distributed_by %></td>
                  <td>
                    <a href="/aid/edit/<%= record.aid_id %>" class="btn btn-sm btn-secondary">Edit</a>
                    <form action="/aid/delete/<%= record.aid_id %>" method="post" class="d-inline">
                      <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Delete this record?');">Delete</button>
                    </form>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </main>
    </div>
    <%- include('../partials/footer') %>
  </body>
</html>
